# =============================================
# Smart Attendance System — Backend .env
# Copy to .env and fill in real values
# =============================================

# -- Server --
PORT=5000
NODE_ENV=development

# -- JWT --
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=8h

# -- Oracle Database --
DB_HOST=adb.ap-seoul-1.oraclecloud.com
DB_PORT=1521
DB_SERVICE=attendance_db
DB_USER=ATTENDANCE_ADMIN
DB_PASSWORD=YourSecurePassword123!

# Oracle Wallet (for Cloud Autonomous DB) — leave empty for on-premise
DB_WALLET_LOCATION=
DB_WALLET_PASSWORD=

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=2

# -- Python AI Microservice --
PYTHON_SERVICE_URL=http://localhost:8000

# -- Email (Nodemailer via Gmail SMTP) --
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=attendance@youruniversity.edu.pk
SMTP_PASS=your_app_password
EMAIL_FROM="Smart Attendance System <attendance@youruniversity.edu.pk>"

# -- OTP Settings --
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# -- Attendance Settings --
MIN_FACE_CONFIDENCE=60
LATE_GRACE_MINUTES=5
MAX_LOCATION_RADIUS_METERS=200

# -- Proxy Detection Thresholds --
PROXY_HIGH_RISK_THRESHOLD=3
PROXY_WINDOW_MINUTES=30

# -- Frontend URL (for CORS) --
FRONTEND_URL=http://localhost:3000
