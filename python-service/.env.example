# =============================================================================
# python-service/.env.example
# Copy to .env and fill in real values
# =============================================================================

PORT=8000
DEBUG=True

# Oracle Database (Matches Node.js config)
DB_USER=ATTENDANCE_ADMIN
DB_PASSWORD=YourSecurePassword123!
# Format: host:port/service_name OR use wallet
DB_DSN=adb.ap-seoul-1.oraclecloud.com:1521/attendance_db

# Face Recognition Settings
FACE_MATCH_TOLERANCE=0.45  # Lower is stricter (0.6 is default in face_recognition, 0.45 is more secure)
