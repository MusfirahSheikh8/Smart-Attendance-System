# Oracle Database (Oracle APEX free tier or on-premise)
DB_HOST=adb.ap-seoul-1.oraclecloud.com
DB_PORT=1521
DB_SERVICE=attendance_db
DB_USER=ATTENDANCE_ADMIN
DB_PASSWORD=123!
DB_LIB_DIR=

# Oracle Wallet (required for Oracle Cloud autonomous DB)
DB_WALLET_LOCATION=./database/wallet
DB_WALLET_PASSWORD=123!

# Node.js oracledb pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=2

# Python cx_Oracle DSN (same host — used by Python microservice)
PYTHON_DB_DSN=${DB_HOST}:${DB_PORT}/${DB_SERVICE}
